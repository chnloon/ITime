<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮覆盖层布局 — 由 ReminderForegroundService 通过 WindowManager.addView() 绘制。
    完全不经过系统通知 API，不受国产 ROM 通知限制。

    设计：半透明背景，顶部横幅卡片
      - 粗体标题
      - 备忘内容（description）
      - 右侧"出发"按钮
      - 无倒计时文字
      - 倒计时结束后自动上滑消失
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true"
    android:focusable="true">

    <!-- 顶部横幅卡片 -->
    <LinearLayout
        android:id="@+id/bannerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="12dp"
        android:background="@drawable/banner_background"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="8dp"
        android:clipToOutline="true">

        <!-- 左侧：标题 + 备忘 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <!-- 标题（粗体） -->
            <TextView
                android:id="@+id/overlayTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#1C1C1E"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 备忘内容（description） -->
            <TextView
                android:id="@+id/overlayContentText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#8E8E93"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 右侧：出发按钮 -->
        <Button
            android:id="@+id/overlayNavigateButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:text="出发"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button_blue"
            android:gravity="center"
            android:paddingHorizontal="18dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:includeFontPadding="false"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
